# --- UAT 環境 Proxy 設定 (供 Vite 模擬使用) ---
VITE_PROXY_API_TARGET=http://uatedmapi.hwacom.com
VITE_PROXY_SSO_TARGET=https://uathws.hwacom.com

# 基礎路徑
VITE_BASE=/

# 介面虛擬位址 (不洩露實體 IP)
VITE_GLOB_API_URL=/api/
VITE_SSO_VERIFY_URL=/api-sso/

# 路由模式
VITE_ROUTER_HISTORY=history

# 是否注入全域 Loading
VITE_INJECT_APP_LOADING=true

# SSO 串接網址 (UAT跳轉)
VITE_HWS_URL=https://uathws.hwacom.com/
VITE_EDM_URL=https://uatedm.hwacom.com

# --- 正式環境 Proxy 設定 (供 Vite 模擬使用) ---
VITE_PROXY_API_TARGET=http://edmapi.hwacom.com
VITE_PROXY_SSO_TARGET=https://hws.hwacom.com

# 基礎路徑
VITE_BASE=/

# 介面虛擬位址 (Nginx 接管)
VITE_GLOB_API_URL=/api/
VITE_SSO_VERIFY_URL=/api-sso/

# 路由模式
VITE_ROUTER_HISTORY=history

# 是否注入全域 Loading
VITE_INJECT_APP_LOADING=true

# SSO 串接網域 (Production跳轉)
VITE_HWS_URL=https://hws.hwacom.com/
VITE_EDM_URL=https://edm.hwacom.com

VITE_BASE=/

# 介面位址 (使用 Nginx 反向代理)
VITE_GLOB_API_URL=/api

# 是否開啟壓縮，可以設置為 none, brotli, gzip
VITE_COMPRESS=none

# 是否開啟 PWA
VITE_PWA=false

# vue-router 的模式 (改為 history 以移除 # 號)
VITE_ROUTER_HISTORY=history

# 是否注入全域 Loading
VITE_INJECT_APP_LOADING=true

# 建置後是否生成 dist.zip
VITE_ARCHIVER=true

# SSO 串接網址 (Production)
VITE_HWS_URL=https://hws.hwacom.com/
VITE_EDM_URL=https://edm.hwacom.com
